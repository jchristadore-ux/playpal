{
  "name": "playpal",
  "version": "1.7.6",
  "private": true,
  "description": "PlayPal \u2014 golf scoring & side-game companion. Live scorecards, Wolf/Nassau/Skins payouts, trip dashboards, and cross-device sync.",
  "type": "module",
  "scripts": {
    "build": "node scripts/build.mjs",
    "icons": "node scripts/make-icons.mjs",
    "test": "npm run build && node --test \"tests/**/*.test.mjs\"",
    "dev": "npm run build && npx -y http-server -p 8080 -c-1 .",
    "build:www": "npm run build && node scripts/build-www.mjs",
    "ios:sync": "npm run build:www && npx cap sync ios"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.1",
    "esbuild": "^0.28.1",
    "sharp": "^0.35.0"
  },
  "dependencies": {
    "@capacitor/core": "^8.4.1",
    "@capacitor/ios": "^8.4.1"
  }
}
