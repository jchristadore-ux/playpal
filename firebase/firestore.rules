rules_version = '2';

// PlayPal Firestore rules.
//
// The app signs every client in with Firebase Anonymous Auth, so requiring
// request.auth != null shuts out the open internet (default "test mode"
// rules expire and/or allow anyone, including bots that scan for open
// Firebase projects). Deploy with:
//
//   npx firebase-tools deploy --only firestore:rules
//
// IMPORTANT: Anonymous Auth must be enabled in Firebase Console →
// Authentication → Sign-in method → Anonymous, or the app cannot write.

service cloud.firestore {
  match /databases/{database}/documents {

    // Shared rounds, keyed by sync code (e.g. AB3X9K).
    match /playpal_rounds/{syncCode} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && syncCode.matches('^[A-Z0-9]{4,12}$')
                   && request.resource.size() < 50;
    }

    // Golf trips.
    match /golf_trips/{tripId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && tripId.matches('^trip_[0-9]+$');
      allow delete: if request.auth != null;
    }

    // Everything else: denied.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
