{
  "rules": {
    ".read": false,
    ".write": false,
    "players": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "courses": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "saved_rounds": {
      ".read": "auth != null",
      "$syncCode": {
        ".write": "auth != null && $syncCode.matches(/^[A-Z0-9]{4,12}$/)"
      }
    }
  }
}
